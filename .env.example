# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง: cp .env.example .env
# ห้าม commit .env (มีข้อมูลลับ) — commit เฉพาะ .env.example นี้

# PostgreSQL connection string
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# ค่า HOST/PORT/USER/PASSWORD/DATABASE ให้ตรงกับ docker-compose (dev port = 5434)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5434/DATABASE?schema=public"

# Better Auth
# BETTER_AUTH_SECRET: สร้าง random string >= 32 ตัว (เช่น `openssl rand -base64 32`) — ห้าม commit ค่าจริง
BETTER_AUTH_SECRET="CHANGE_ME_RANDOM_STRING_AT_LEAST_32_CHARS"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
