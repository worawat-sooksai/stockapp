# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง: cp .env.example .env
# ห้าม commit .env (มีข้อมูลลับ) — commit เฉพาะ .env.example นี้

# ---------- PostgreSQL ----------
# ใช้โดย service `db` ใน docker-compose.yml
POSTGRES_USER="stock"
POSTGRES_PASSWORD="stock"
POSTGRES_DB="stockapp"
# port ที่ publish ออกมานอก container — ตั้งเป็นค่าอื่นถ้ามี postgres ตัวอื่นใช้ 5432 อยู่
POSTGRES_PORT="55432"

# ---------- Database connection ----------
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# ค่านี้ใช้กับ `pnpm dev` บนเครื่องเท่านั้น (host = localhost)
# service app/migrate ใน docker compose **ไม่ได้อ่านค่านี้** — compose ประกอบ URL เอง
# จาก POSTGRES_* โดยใช้ host = `db` (ชื่อ service) ให้อัตโนมัติ
DATABASE_URL="postgresql://stock:stock@localhost:5432/stockapp?schema=public"

# ---------- Better Auth ----------
# BETTER_AUTH_SECRET: สร้าง random string >= 32 ตัว (เช่น `openssl rand -base64 32`) — ห้าม commit ค่าจริง
BETTER_AUTH_SECRET="CHANGE_ME_RANDOM_STRING_AT_LEAST_32_CHARS"

# 2 ค่านี้ใช้กับ `pnpm dev` — ใน compose จะ derive จาก APP_PORT ให้อัตโนมัติ
BETTER_AUTH_URL="http://localhost:3000"
# ⚠️ NEXT_PUBLIC_* ถูก inline เข้า client bundle ตอน `next build`
# เปลี่ยนค่านี้แล้วต้อง build image ใหม่ (`docker compose build app`) แก้ตอน runtime ไม่มีผล
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- App ----------
# port ที่ publish ออกมานอก container (compose ใช้ค่านี้ตั้ง BETTER_AUTH_URL/NEXT_PUBLIC_APP_URL ด้วย)
APP_PORT="3300"

# ---------- Seed ----------
# ⚠️ RUN_SEED=true จะ **ลบ Product และ StockTransaction ทั้งหมด** แล้ว insert ข้อมูลตัวอย่างใหม่
# (prisma/seed.ts เรียก deleteMany() ก่อน) — ใช้เฉพาะ dev เท่านั้น, production ต้องเป็น false เสมอ
RUN_SEED="false"
